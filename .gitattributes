# ZidStore Tunnel - Git Attributes
# Ensure proper handling of line endings

* text=auto

# Shell scripts - always LF
*.sh text eol=lf
*.bash text eol=lf

# Service files - always LF
*.service text eol=lf

# JSON files - always LF
*.json text eol=lf

# Encoded script - always LF (critical for bash compatibility)
zidstoretunnel text eol=lf

# Binary files
*.gz binary
*.zip binary